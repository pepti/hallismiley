PORT=3000

# PostgreSQL connection string
# Local example: postgresql://postgres:password@localhost:5432/halliprojects
# Hosted  example: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# Set to true when connecting to hosted PostgreSQL (Supabase, Railway, Render)
DB_SSL=false

# A07 Auth: admin credentials — run setup-admin.js to regenerate the hash
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=

# A05 CORS: comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# RSA keys for RS256 JWT signing (newlines encoded as \n)
# Generate with: openssl genrsa -out keys/private.pem 2048 && openssl rsa -in keys/private.pem -pubout -out keys/public.pem
# For production: paste single-line PEM here (replace literal newlines with \n)
PRIVATE_KEY=
PUBLIC_KEY=

# Optional: Sentry error tracking DSN (leave blank to disable)
SENTRY_DSN=
