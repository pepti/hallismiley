# ══════════════════════════════════════════════════════════════════════════════
# HalliProjects — Production Environment Variables
# Copy this file to .env and fill in all required values before deploying.
# Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Railway provides this automatically as ${{Postgres.DATABASE_URL}}.
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Comma-separated list of origins allowed to make cross-origin requests.
# Must exactly match the protocol+host+port of your frontend (no trailing slash).
# Example: https://hallismiley.is,https://www.hallismiley.is
ALLOWED_ORIGINS=

# Node environment. Set to "production" for live deployments.
# Controls secure cookies, Sentry sample rates, and other prod-only behaviour.
NODE_ENV=production

# Random 32+ character secret for CSRF double-submit cookie signing.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the HTTP server listens on. Railway sets this automatically.
# Default: 3000
PORT=3000

# Pino log level. Use "debug" for troubleshooting; keep "info" in production.
# Levels: trace | debug | info | warn | error | fatal
# Default: info
LOG_LEVEL=info

# Sentry project DSN for error tracking and performance monitoring.
# Leave blank to disable Sentry entirely.
# Example: https://abc123@o0.ingest.sentry.io/123456
SENTRY_DSN=

# Bearer token required to access GET /metrics (Prometheus endpoint).
# If blank, /metrics is only accessible from localhost.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
METRICS_TOKEN=

# Webhook URL for critical alert notifications (Slack, Discord, PagerDuty).
# Leave blank to disable webhook alerts.
# Example: https://hooks.slack.com/services/T00/B00/xxxx
ALERT_WEBHOOK_URL=

# Set to "true" to enforce SSL on the PostgreSQL connection.
# Required for hosted databases (Railway, Supabase, Render, Neon).
# Default: false (for local development)
DB_SSL=true

# ── Email (Google Workspace SMTP) ─────────────────────────────────────────────

# Gmail / Google Workspace account used to send transactional email.
# Use a Google App Password (not your regular account password).
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_USER=halli@hallismiley.is
SMTP_PASS=

# Optional: override the From address (defaults to noreply@hallismiley.is).
# SMTP_FROM=noreply@hallismiley.is

# Public base URL used to build verification and reset links in emails.
# Must match the URL users actually visit (no trailing slash).
APP_URL=https://www.hallismiley.is

# ── Google Sign-In (OAuth 2.0 + PKCE) ─────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# (type: Web application). Leave blank to disable Google sign-in entirely —
# the button will 500 if clicked without these set.
#
# Authorized redirect URI must EXACTLY match GOOGLE_REDIRECT_URI below. In
# dev, add http://localhost:3000/auth/google/callback to Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://www.hallismiley.is/auth/google/callback

# ── Facebook Sign-In (OAuth 2.0, no PKCE) ─────────────────────────────────────
# Create an app at https://developers.facebook.com/apps/
# Add the "Facebook Login" product, then set the OAuth redirect URI below.
# App must be in "Live" mode for non-admin users to log in.
# Leave blank to disable Facebook sign-in (the button will error if clicked).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://www.hallismiley.is/auth/facebook/callback

# ── Auto-translation (EN → IS on admin save) ─────────────────────────────────
# Feature flag. Set to "true" to enable server-side Anthropic translation of
# empty IS fields when an admin saves English content. Leave blank/false to
# keep the feature dark (all saves behave exactly as they do today).
TRANSLATE_ENABLED=

# Anthropic API key. Required when TRANSLATE_ENABLED=true. Leave blank to
# hard-disable translation even if the flag is on.
ANTHROPIC_API_KEY=

# Optional: model override. Defaults to claude-haiku-4-5.
# TRANSLATE_MODEL=claude-haiku-4-5

# Optional: per-call timeout in milliseconds. Defaults to 8000 (8s).
# On timeout, the save still succeeds — only the IS field stays null.
# TRANSLATE_TIMEOUT_MS=8000
