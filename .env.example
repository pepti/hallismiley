PORT=3000

# PostgreSQL connection string
# Local example: postgresql://postgres:password@localhost:5432/halliprojects
# Hosted  example: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# Set to true when connecting to hosted PostgreSQL (Supabase, Railway, Render)
DB_SSL=false

# A05 CORS: comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# Optional: Sentry error tracking DSN (leave blank to disable)
SENTRY_DSN=

# ── Observability ─────────────────────────────────────────────────────────────

# Bearer token required to access GET /metrics (leave blank for localhost-only access)
METRICS_TOKEN=

# Webhook URL for critical alerts (Slack, Discord, PagerDuty — leave blank to disable)
ALERT_WEBHOOK_URL=

# Pino log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info

# ── Initial admin user setup ──────────────────────────────────────────────────
# After running migrations, create your first admin user with:
#   node server/scripts/setup-admin.js <username> <email> <password>
