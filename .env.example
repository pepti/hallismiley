# ══════════════════════════════════════════════════════════════════════════════
# HalliProjects — Production Environment Variables
# Copy this file to .env and fill in all required values before deploying.
# Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# On Azure Web App, set this in the App Service → Configuration → Application
# settings. Use Azure Database for PostgreSQL (flexible server) in production.
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Comma-separated list of origins allowed to make cross-origin requests.
# Must exactly match the protocol+host+port of your frontend (no trailing slash).
# Example: https://hallismiley.is,https://www.hallismiley.is
ALLOWED_ORIGINS=

# Node environment. Set to "production" for live deployments.
# Controls secure cookies, Sentry sample rates, and other prod-only behaviour.
NODE_ENV=production

# Random 32+ character secret for CSRF double-submit cookie signing.
# REQUIRED in production — the server will refuse to start without it.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
CSRF_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the HTTP server listens on. Azure Web App sets PORT automatically.
# Default: 3000
PORT=3000

# Directory where runtime uploads (avatars, project media, party photos) are
# written. On Azure Web App, set this to the mount path of the attached Azure
# Files share so uploads survive restarts. Default: project-relative `public/assets`.
# Example: UPLOAD_ROOT=/mnt/uploads
UPLOAD_ROOT=

# Pino log level. Use "debug" for troubleshooting; keep "info" in production.
# Levels: trace | debug | info | warn | error | fatal
# Default: info
LOG_LEVEL=info

# ── Sentry error tracking ─────────────────────────────────────────────────────

# Sentry project DSN. Leave blank to disable Sentry entirely.
# Example: https://abc123@o0.ingest.sentry.io/123456
SENTRY_DSN=

# Fraction of transactions sampled for tracing. 0 = off, 1 = 100%.
# Default: 0.1
SENTRY_TRACES_SAMPLE_RATE=0.1

# Fraction of sampled transactions profiled. 0 = off, 1 = 100%.
# Default: 0 (profiling disabled unless you explicitly want it)
SENTRY_PROFILES_SAMPLE_RATE=0

# ── Observability ─────────────────────────────────────────────────────────────

# Bearer token required to access GET /metrics (Prometheus endpoint).
# If blank, /metrics is only accessible from localhost in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
METRICS_TOKEN=

# Webhook URL for critical alert notifications (Slack, Discord, PagerDuty).
# Leave blank to disable webhook alerts; Sentry will still capture them if DSN is set.
# Example: https://hooks.slack.com/services/T00/B00/xxxx
ALERT_WEBHOOK_URL=

# ── Database SSL ──────────────────────────────────────────────────────────────

# Set to "true" to enforce SSL on the PostgreSQL connection.
# Required for Azure Database for PostgreSQL and most hosted services.
# Default: false (for local development).
DB_SSL=true

# ── Email (Resend) ────────────────────────────────────────────────────────────

# Resend API key — create at https://resend.com/api-keys
# When blank, email sends fall back to console logging (dev-friendly).
RESEND_API_KEY=

# Public From address for transactional email. Must be a verified domain in Resend.
EMAIL_FROM=noreply@hallismiley.is

# Public base URL used to build verification and reset links in emails.
# Must match the URL users actually visit (no trailing slash).
APP_URL=https://www.hallismiley.is

# Set to "true" to require new users to verify their email before logging in.
# Leave blank (or false) during development — tokens are logged to the console.
# Flip to "true" in production when RESEND_API_KEY is configured.
REQUIRE_EMAIL_VERIFICATION=

# ── Admin bootstrap ───────────────────────────────────────────────────────────

# Optional: seed an admin account on first boot. Only applied when no admin
# exists yet. Remove from environment after the account is created.
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Google Sign-In (OAuth 2.0 + PKCE) ─────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# (type: Web application). Leave blank to disable Google sign-in entirely —
# the button will redirect with error=google_not_configured if clicked.
#
# Authorized redirect URI must EXACTLY match GOOGLE_REDIRECT_URI below. In
# dev, add http://localhost:3000/auth/google/callback to Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://www.hallismiley.is/auth/google/callback

# ── Facebook Sign-In (OAuth 2.0, no PKCE) ─────────────────────────────────────
# Create an app at https://developers.facebook.com/apps/
# Add the "Facebook Login" product, then set the OAuth redirect URI below.
# App must be in "Live" mode for non-admin users to log in.
# Leave blank to disable Facebook sign-in (the button will error if clicked).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://www.hallismiley.is/auth/facebook/callback
