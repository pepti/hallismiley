{
  "root": true,
  "extends": ["eslint:recommended"],
  "rules": {
    "no-unused-vars":      ["error", { "varsIgnorePattern": "^_", "argsIgnorePattern": "^_" }],
    "no-console":          "off",
    "no-var":              "error",
    "prefer-const":        ["error", { "destructuring": "all" }],
    "no-implicit-globals": "error",
    "no-throw-literal":    "error",
    "no-return-await":     "error",
    "eqeqeq":              ["error", "smart"],
    "no-promise-executor-return": "error",
    "require-atomic-updates":     "off"
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "overrides": [
    {
      "files": ["server/**/*.js", "jest.config.js"],
      "env": {
        "node": true,
        "commonjs": true,
        "es2022": true
      },
      "parserOptions": {
        "sourceType": "script",
        "ecmaVersion": 2022
      }
    },
    {
      "files": ["tests/**/*.js"],
      "env": {
        "node": true,
        "commonjs": true,
        "jest": true,
        "es2022": true
      },
      "parserOptions": {
        "sourceType": "script",
        "ecmaVersion": 2022
      }
    },
    {
      "files": ["public/js/**/*.js"],
      "env": {
        "browser": true,
        "es2022": true
      },
      "parserOptions": {
        "sourceType": "module",
        "ecmaVersion": 2022
      }
    },
    {
      "files": ["e2e/**/*.js", "playwright.config.js"],
      "env": {
        "node": true,
        "commonjs": true,
        "browser": true,
        "es2022": true
      },
      "parserOptions": {
        "sourceType": "script",
        "ecmaVersion": 2022
      }
    }
  ]
}
